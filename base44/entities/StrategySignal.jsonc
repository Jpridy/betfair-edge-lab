{
  "name": "StrategySignal",
  "type": "object",
  "properties": {
    "strategyName": {
      "type": "string"
    },
    "decisionSource": {
      "type": "string"
    },
    "selectionDiagnostics": {
      "type": "object"
    },
    "marketId": {
      "type": "string"
    },
    "betfairMarketId": {
      "type": "string"
    },
    "selectionId": {
      "type": "string"
    },
    "runnerId": {
      "type": "string"
    },
    "runnerName": {
      "type": "string"
    },
    "eventId": {
      "type": "string"
    },
    "eventName": {
      "type": "string"
    },
    "marketName": {
      "type": "string"
    },
    "marketType": {
      "type": "string"
    },
    "marketTypeCode": {
      "type": "string"
    },
    "opponentSelectionId": {
      "type": "string"
    },
    "side": {
      "type": "string",
      "enum": [
        "BACK",
        "LAY"
      ]
    },
    "odds": {
      "type": "number"
    },
    "stakeSuggestion": {
      "type": "number"
    },
    "liability": {
      "type": "number"
    },
    "maxProfit": {
      "type": "number"
    },
    "maxLoss": {
      "type": "number"
    },
    "commissionRate": {
      "type": "number"
    },
    "rawCommissionRate": {
      "type": "number"
    },
    "normalizedCommissionRate": {
      "type": "number"
    },
    "commissionNormalizationApplied": {
      "type": "boolean"
    },
    "spreadTicks": {
      "type": "number"
    },
    "persistenceType": {
      "type": "string",
      "enum": [
        "LAPSE",
        "PERSIST",
        "MARKET_ON_CLOSE"
      ]
    },
    "proofMode": {
      "type": "boolean",
      "default": false
    },
    "proofReason": {
      "type": "string"
    },
    "modelProbability": {
      "type": "number"
    },
    "impliedProbability": {
      "type": "number"
    },
    "fairOdds": {
      "type": "number"
    },
    "edgePercent": {
      "type": "number"
    },
    "expectedValue": {
      "type": "number"
    },
    "expectedROI": {
      "type": "number"
    },
    "confidence": {
      "type": "number"
    },
    "dataQuality": {
      "type": "number"
    },
    "signalStatus": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "blocked",
        "executed",
        "expired",
        "cancelled"
      ],
      "default": "proposed"
    },
    "reason": {
      "type": "string"
    },
    "dataSource": {
      "type": "string",
      "enum": [
        "MARKET_ONLY",
        "MARKET_ONLY_PROOF",
        "BETFAIR_METADATA_PLUS_MARKET",
        "EXTERNAL_FORM_PLUS_MARKET",
        "FEATHERLESS",
        "OPENAI_ADJUSTED",
        "FALLBACK"
      ]
    },
    "probabilitySource": {
      "type": "string"
    },
    "finalProbabilityUsedInEV": {
      "type": "number"
    },
    "probabilityLabel": {
      "type": "string"
    },
    "formDataStatus": {
      "type": "string"
    },
    "formDataCompleteness": {
      "type": "number"
    },
    "marketScore": {
      "type": "number"
    },
    "metadataScore": {
      "type": "number"
    },
    "externalFormScore": {
      "type": "number"
    },
    "finalScore": {
      "type": "number"
    },
    "clvEstimate": {
      "type": "number"
    },
    "orderId": {
      "type": "string"
    },
    "blocker": {
      "type": "string"
    },
    "priceFeedStatus": {
      "type": "string"
    },
    "priceAgeSeconds": {
      "type": "number"
    },
    "invalidTestRecord": {
      "type": "boolean",
      "default": false
    },
    "excludeFromPerformance": {
      "type": "boolean",
      "default": false
    },
    "exclusionReason": {
      "type": "string"
    },
    "settlementWorkerRunId": {
      "type": "string"
    }
  },
  "required": [
    "strategyName",
    "marketId"
  ]
}