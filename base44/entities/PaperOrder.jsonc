      "type": "string"
    },
    "rejection_reason": {
      "type": "string"
    },
    "failed_validation_field": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "settlementStatus": {
      "type": "string"
    },
    "settlementCheckStatus": {
      "type": "string"
    },
    "nextSettlementRetryAt": {
      "type": "string"
    },
    "resultSource": {
      "type": "string"
    },
    "resultConfidence": {
      "type": "number"
    },
    "settledAt": {
      "type": "string"
    },
    "marketStatusAtSettlement": {
      "type": "string"
    },
    "marketStatusAtLastCheck": {
      "type": "string"
    },
    "winnerSelectionIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "winnerSelectionId": {
      "type": "string"
    },
    "placedSelectionIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
