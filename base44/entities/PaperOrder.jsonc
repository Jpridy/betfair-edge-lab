      "type": "boolean",
      "default": false
    },
    "voidReason": {
      "type": "string"
    },
    "numberOfWinners": {
      "type": "number"
    },
    "placeTerms": {
      "type": "number"
    },
    "liability": {
      "type": "number",
      "minimum": 0
    },
    "requestedCalculation": {
      "type": "object"
    },
    "matchedCalculation": {
      "type": "object"
    },
    "remainingUnmatchedCalculation": {
      "type": "object"
    },
