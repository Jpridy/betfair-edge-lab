      "type": "string"
    },
    "marketTypeCode": {
      "type": "string"
    },
    "side": {
      "type": "string",
      "enum": [
        "BACK",
        "LAY"
      ]
    },
    "orderType": {
      "type": "string"
    },
    "size": {
      "type": "number",
      "minimum": 0
    },
    "price": {
      "type": "number",
      "exclusiveMinimum": 1
    },
    "persistenceType": {
      "type": "string"
    },
    "customerRef": {
      "type": "string"
    },
    "customerStrategyRef": {
      "type": "string"
    },
    "handicap": {
      "type": "number"
    },
    "paper_mode": {
      "type": "boolean",
      "default": true
    },
    "liveMode": {
      "type": "boolean",
      "default": false
    },
    "proofMode": {
      "type": "boolean",
      "default": false
    },
    "proofReason": {
      "type": "string"
    },
    "betfairBetId": {
      "type": "string"
    },
    "requested_size": {
      "type": "number",
      "minimum": 0
    },
    "matched_size": {
      "type": "number",
      "minimum": 0
    },
    "remaining_size": {
      "type": "number",
      "minimum": 0
    },
    "average_price_matched": {
      "type": "number"
    },
    "requested_price": {
      "type": "number"
    },
    "matched_price": {
      "type": "number"
    },
    "placed_date": {
      "type": "string"
    },
    "matched_date": {
      "type": "string"
    },
    "settled_date": {
      "type": "string"
    },
    "lapse_reason": {
      "type": "string"
    },
