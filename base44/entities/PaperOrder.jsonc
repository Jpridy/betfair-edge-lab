      "type": "string"
    },
    "runnerName": {
      "type": "string"
    },
    "horseNumber": {
      "type": "number"
    },
    "marketName": {
      "type": "string"
    },
    "venue": {
      "type": "string"
    },
    "raceNumber": {
      "type": "number"
    },
    "marketStartTime": {
      "type": "string"
    },
    "raceStartTime": {
      "type": "string"
    },
    "eventName": {
      "type": "string"
    },
