      "type": "number"
    },
    "simulatedAveragePrice": {
      "type": "number"
    },
    "simulatedStatus": {
      "type": "string"
    },
    "simulatedSettlement": {
      "type": "string"
    },
    "simulatedCommission": {
      "type": "number"
    },
    "simulatedCLV": {
      "type": "number"
    },
    "simulatedSlippage": {
      "type": "number"
    },
    "requestedOdds": {
      "type": "number",
      "exclusiveMinimum": 1
    },
    "matchedOdds": {
      "type": "number"
    },
    "requestedStake": {
      "type": "number",
      "minimum": 0
    },
    "matchedStake": {
      "type": "number",
      "minimum": 0
    },
    "commissionRateUsed": {
      "type": "number",
      "minimum": 0,
      "maximum": 0.2
    },
    "rawCommissionRate": {
      "type": "number"
    },
    "normalizedCommissionRate": {
      "type": "number",
      "minimum": 0,
      "maximum": 0.2
    },
    "commissionNormalizationApplied": {
      "type": "boolean"
    },
    "commissionSource": {
      "type": "string"
    },
    "commission_calculation_status": {
      "type": "string"
    },
    "expectedValue": {
      "type": "number"
    },
    "modelProbability": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "probabilityDecimal": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "impliedProbability": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "impliedProbabilityDecimal": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidencePercent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "expectedROI": {
      "type": "number"
    },
    "edge": {
      "type": "number"
    },
    "rawProbabilityEdge": {
      "type": "number"
    },
    "commissionAdjustedEdge": {
      "type": "number"
    },
    "calculationResult": {
      "type": "object"
    },
    "mathematicalInvariantsPassed": {
      "type": "boolean"
    },
    "result": {
      "type": "string",
      "enum": [
        "pending",
        "won",
        "lost",
        "void"
      ]
    },
    "grossProfit": {
      "type": "number"
    },
    "commission": {
      "type": "number"
    },
    "netProfit": {
      "type": "number"
    },
    "netPL": {
      "type": "number"
    },
    "marketGrossProfit": {
      "type": "number"
    },
    "marketCommission": {
      "type": "number"
    },
    "closingOdds": {
      "type": "number"
    },
    "clv": {
      "type": "number"
    },
    "slippage": {
      "type": "number"
    },
    "entryReason": {
      "type": "string"
    },
    "exitReason": {
      "type": "string"
    },
    "warningFlags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "paperSimulationQuality": {
      "type": "string"
    },
    "dataSource": {
      "type": "string"
    },
    "validationRan": {
      "type": "boolean",
      "default": false
    },
    "riskCheckRan": {
      "type": "boolean",
      "default": false
    },
    "softOverridesApplied": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hardBlockersChecked": {
      "type": "boolean",
      "default": false
    },
    "settlementLastCheckedAt": {
      "type": "string"
    },
    "settlementAttempts": {
      "type": "number",
      "default": 0
    },
    "settlementError": {
      "type": "string"
    },
    "settlementWorkerRunId": {
      "type": "string"
    },
    "settlementKey": {
      "type": "string"
    },
    "invalidTestRecord": {
      "type": "boolean",
      "default": false
    },
    "excludeFromPerformance": {
      "type": "boolean",
      "default": false
    },
    "exclusionReason": {
      "type": "string"
    },
    "priceFeedStatus": {
      "type": "string"
    },
    "priceAgeSeconds": {
      "type": "number"
    }
