{
  "name": "Runner",
  "type": "object",
  "properties": {
    "marketId": {
      "type": "string"
    },
    "betfairSelectionId": {
      "type": "string"
    },
    "selectionId": {
      "type": "string"
    },
    "runnerName": {
      "type": "string"
    },
    "horseNumber": {
      "type": "number"
    },
    "handicap": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "REMOVED",
        "WINNER",
        "LOSER",
        "HIDDEN",
        "PLACED"
      ]
    },
    "adjustmentFactor": {
      "type": "number"
    },
    "lastPriceTraded": {
      "type": "number"
    },
    "totalMatched": {
      "type": "number"
    },
    "availableToBack": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "availableToLay": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "tradedVolume": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "bestBackPrice": {
      "type": "number"
    },
    "bestBackSize": {
      "type": "number"
    },
    "bestLayPrice": {
      "type": "number"
    },
    "bestLaySize": {
      "type": "number"
    },
    "lastTradedPrice": {
      "type": "number"
    },
    "tradedVolumeAmount": {
      "type": "number"
    },
    "spreadTicks": {
      "type": "number"
    },
    "impliedProbability": {
      "type": "number"
    },
    "modelProbability": {
      "type": "number"
    },
    "edge": {
      "type": "number"
    },
    "clvEstimate": {
      "type": "number"
    },
    "favouriteRank": {
      "type": "number"
    },
    "isFavourite": {
      "type": "boolean",
      "default": false
    },
    "isOutsider": {
      "type": "boolean",
      "default": false
    },
    "strategySignalStatus": {
      "type": "string",
      "enum": [
        "none",
        "active",
        "executed",
        "expired",
        "blocked",
        "rejected"
      ]
    },
    "rejectedSignalReason": {
      "type": "string"
    },
    "availableToBackLadder": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "availableToLayLadder": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "tradedVolumeByPrice": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "midPrice": {
      "type": "number"
    },
    "weightedMidPrice": {
      "type": "number"
    },
    "microPrice": {
      "type": "number"
    },
    "bookPercentage": {
      "type": "number"
    },
    "liquidityRank": {
      "type": "number"
    },
    "priceMovementShortTerm": {
      "type": "number"
    },
    "priceMovementMediumTerm": {
      "type": "number"
    },
    "tradedVolumeDelta": {
      "type": "number"
    },
    "backPressure": {
      "type": "number"
    },
    "layPressure": {
      "type": "number"
    },
    "orderBookImbalance": {
      "type": "number"
    },
    "bspNearPrice": {
      "type": "number"
    },
    "bspFarPrice": {
      "type": "number"
    },
    "spAvailable": {
      "type": "number"
    },
    "spTraded": {
      "type": "number"
    },
    "formDataStatus": {
      "type": "string",
      "enum": [
        "MARKET_ONLY",
        "PARTIAL_BETFAIR_METADATA",
        "FULL_EXTERNAL_FORM"
      ]
    },
    "formDataCompleteness": {
      "type": "number"
    },
    "raceFormProfile": {
      "type": "object"
    }
  },
  "required": [
    "marketId",
    "runnerName"
  ]
}