{
  "name": "FeatherlessSettings",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "modelName": {
      "type": "string",
      "default": "deepseek-ai/DeepSeek-V4-Pro"
    },
    "temperature": {
      "type": "number",
      "default": 0.1
    },
    "maxTokens": {
      "type": "number",
      "default": 4000
    },
    "timeoutSeconds": {
      "type": "number",
      "default": 120
    },
    "minConfidence": {
      "type": "number",
      "default": 50
    },
    "minEdge": {
      "type": "number",
      "default": 3
    },
    "minExpectedROI": {
      "type": "number",
      "default": 1
    },
    "paperTradeOnly": {
      "type": "boolean",
      "default": true
    },
    "allowLiveHandoff": {
      "type": "boolean",
      "default": false
    },
    "storeLogs": {
      "type": "boolean",
      "default": true
    },
    "minOdds": {
      "type": "number",
      "default": 1.5
    },
    "maxOdds": {
      "type": "number",
      "default": 50
    },
    "minLiquidity": {
      "type": "number",
      "default": 20
    },
    "maxSpread": {
      "type": "number",
      "default": 7
    },
    "timeWindowStart": {
      "type": "number",
      "default": 500
    },
    "timeWindowEnd": {
      "type": "number",
      "default": 30
    },
    "stakingMode": {
      "type": "string",
      "default": "confidence_weighted_fractional_kelly"
    },
    "webResearchEnabled": {
      "type": "boolean",
      "default": false
    },
    "aiDecisionMode": {
      "type": "string",
      "enum": [
        "strict",
        "balanced_paper",
        "active_paper_discovery",
        "paper_proof"
      ],
      "default": "strict"
    },
    "requireExternalFormData": {
      "type": "boolean",
      "default": false
    },
    "targetPaperBetsPerDay": {
      "type": "string",
      "enum": [
        "very_low",
        "low",
        "medium",
        "high"
      ],
      "default": "low"
    },
    "winMinOdds": {
      "type": "number",
      "default": 1.5
    },
    "winMaxOdds": {
      "type": "number",
      "default": 50
    },
    "winMinLiquidity": {
      "type": "number",
      "default": 20
    },
    "winMaxSpreadTicks": {
      "type": "number",
      "default": 7
    },
    "winMinEdge": {
      "type": "number",
      "default": 3
    },
    "winMinROI": {
      "type": "number",
      "default": 1
    },
    "placeMinOdds": {
      "type": "number",
      "default": 1.2
    },
    "placeMaxOdds": {
      "type": "number",
      "default": 30
    },
    "placeMinLiquidity": {
      "type": "number",
      "default": 10
    },
    "placeMaxSpreadTicks": {
      "type": "number",
      "default": 7
    },
    "placeMinEdge": {
      "type": "number",
      "default": 2
    },
    "placeMinROI": {
      "type": "number",
      "default": 1
    },
    "h2hMinOdds": {
      "type": "number",
      "default": 1.2
    },
    "h2hMaxOdds": {
      "type": "number",
      "default": 15
    },
    "h2hMinLiquidity": {
      "type": "number",
      "default": 10
    },
    "h2hMaxSpreadTicks": {
      "type": "number",
      "default": 5
    },
    "h2hMinEdge": {
      "type": "number",
      "default": 3
    },
    "h2hMinROI": {
      "type": "number",
      "default": 1
    },
    "allowHedging": {
      "type": "boolean",
      "default": false
    },
    "debugScanMode": {
      "type": "boolean",
      "default": false
    },
    "externalSearchEnabled": {
      "type": "boolean",
      "default": false
    },
    "maxExternalProbabilityAdjustment": {
      "type": "number",
      "default": 0.05
    },
    "minExternalSourceCount": {
      "type": "number",
      "default": 2
    },
    "minExternalDataQuality": {
      "type": "number",
      "default": 50
    },
    "requireExternalSearchForLiveBetting": {
      "type": "boolean",
      "default": false
    },
    "externalSearchCacheTtlMinutes": {
      "type": "number",
      "default": 5
    },
    "paperProofMode": {
      "type": "boolean",
      "default": false
    },
    "featherlessAlwaysRequired": {
      "type": "boolean",
      "default": true
    },
    "requireFullRacePack": {
      "type": "boolean",
      "default": true
    },
    "maxRacesPerCycle": {
      "type": "number",
      "default": 1
    },
    "maxRunnersPerRacePack": {
      "type": "number",
      "default": 30
    },
    "maxMarketsPerRacePack": {
      "type": "number",
      "default": 10
    },
    "includeOpenAIResearchInRacePack": {
      "type": "boolean",
      "default": true
    },
    "includeRiskContextInRacePack": {
      "type": "boolean",
      "default": true
    },
    "allowMarketOnlyFallbackInDebug": {
      "type": "boolean",
      "default": true
    },
    "allowMarketOnlyFallbackInPaperProof": {
      "type": "boolean",
      "default": true
    },
    "allowMarketOnlyFallbackInNormalMode": {
      "type": "boolean",
      "default": false
    },
    "featherlessTimeoutMs": {
      "type": "number",
      "default": 120000
    },
    "featherlessStrictJson": {
      "type": "boolean",
      "default": true
    },
    "paperProofExternalSearchEnabled": {
      "type": "boolean",
      "default": false
    },
    "favouriteContextEnabled": {
      "type": "boolean",
      "default": true
    },
    "favouriteContextMaxProbabilityAdjustment": {
      "type": "number",
      "default": 0.03
    },
    "favouriteStrongConfidenceBoost": {
      "type": "number",
      "default": 5
    },
    "favouriteWeakConfidencePenalty": {
      "type": "number",
      "default": 10
    },
    "requireFavouriteContextForWinMarket": {
      "type": "boolean",
      "default": false
    },
    "allowFavouriteLayOnlyWhenVulnerable": {
      "type": "boolean",
      "default": true
    },
    "racePackCacheTtlMinutes": {
      "type": "number",
      "default": 30
    },
    "aiResultCacheTtlSeconds": {
      "type": "number",
      "default": 90
    },
    "rerunAiOnMajorPriceMove": {
      "type": "boolean",
      "default": true
    },
    "majorPriceMoveTicks": {
      "type": "number",
      "default": 5
    },
    "prewarmOpenAIWithinMinutes": {
      "type": "number",
      "default": 30
    },
    "completedRaceRetentionHours": {
      "type": "number",
      "default": 6
    }
  },
  "required": [
    "modelName"
  ]
}