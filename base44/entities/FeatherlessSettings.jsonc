{
  "name": "FeatherlessSettings",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "modelName": {
      "type": "string",
      "default": "deepseek-ai/DeepSeek-V4-Flash"
    },
    "temperature": {
      "type": "number",
      "default": 0.1
    },
    "maxTokens": {
      "type": "number",
      "default": 4000
    },
    "timeoutSeconds": {
      "type": "number",
      "default": 60
    },
    "minConfidence": {
      "type": "number",
      "default": 50
    },
    "minEdge": {
      "type": "number",
      "default": 3
    },
    "minExpectedROI": {
      "type": "number",
      "default": 1
    },
    "paperTradeOnly": {
      "type": "boolean",
      "default": true
    },
    "allowLiveHandoff": {
      "type": "boolean",
      "default": false
    },
    "storeLogs": {
      "type": "boolean",
      "default": true
    },
    "minOdds": {
      "type": "number",
      "default": 1.5
    },
    "maxOdds": {
      "type": "number",
      "default": 50
    },
    "minLiquidity": {
      "type": "number",
      "default": 20
    },
    "maxSpread": {
      "type": "number",
      "default": 7
    },
    "timeWindowStart": {
      "type": "number",
      "default": 500
    },
    "timeWindowEnd": {
      "type": "number",
      "default": 30
    },
    "stakingMode": {
      "type": "string",
      "default": "confidence_weighted_fractional_kelly"
    },
    "webResearchEnabled": {
      "type": "boolean",
      "default": false
    },
    "aiDecisionMode": {
      "type": "string",
      "enum": [
        "strict",
        "balanced_paper",
        "active_paper_discovery"
      ],
      "default": "strict"
    },
    "requireExternalFormData": {
      "type": "boolean",
      "default": false
    },
    "targetPaperBetsPerDay": {
      "type": "string",
      "enum": [
        "very_low",
        "low",
        "medium",
        "high"
      ],
      "default": "low"
    },
    "winMinOdds": {
      "type": "number",
      "default": 1.5
    },
    "winMaxOdds": {
      "type": "number",
      "default": 50
    },
    "winMinLiquidity": {
      "type": "number",
      "default": 20
    },
    "winMaxSpreadTicks": {
      "type": "number",
      "default": 7
    },
    "winMinEdge": {
      "type": "number",
      "default": 3
    },
    "winMinROI": {
      "type": "number",
      "default": 1
    },
    "placeMinOdds": {
      "type": "number",
      "default": 1.2
    },
    "placeMaxOdds": {
      "type": "number",
      "default": 30
    },
    "placeMinLiquidity": {
      "type": "number",
      "default": 10
    },
    "placeMaxSpreadTicks": {
      "type": "number",
      "default": 7
    },
    "placeMinEdge": {
      "type": "number",
      "default": 2
    },
    "placeMinROI": {
      "type": "number",
      "default": 1
    },
    "h2hMinOdds": {
      "type": "number",
      "default": 1.2
    },
    "h2hMaxOdds": {
      "type": "number",
      "default": 15
    },
    "h2hMinLiquidity": {
      "type": "number",
      "default": 10
    },
    "h2hMaxSpreadTicks": {
      "type": "number",
      "default": 5
    },
    "h2hMinEdge": {
      "type": "number",
      "default": 3
    },
    "h2hMinROI": {
      "type": "number",
      "default": 1
    },
    "allowHedging": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "modelName"
  ]
}