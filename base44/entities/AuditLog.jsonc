{
  "name": "AuditLog",
  "type": "object",
  "properties": {
    "action": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "api",
        "mode",
        "settings",
        "strategy",
        "risk",
        "order",
        "emergency",
        "system"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ]
    },
    "user": {
      "type": "string"
    },
    "details": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "objectType": {
      "type": "string"
    },
    "objectName": {
      "type": "string"
    },
    "beforeValue": {
      "type": "string"
    },
    "afterValue": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    }
  },
  "required": [
    "action",
    "category",
    "severity"
  ]
}